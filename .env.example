# This project reads no secrets or API keys. Training and data download use only
# public HTTPS endpoints. The variables below are optional knobs the scripts and
# PyTorch honor; copy to .env only if you want to override defaults.

# Number of CPU threads PyTorch uses for the CPU proof run (defaults to all cores).
OMP_NUM_THREADS=8

# Directory for downloaded raw corpora (kept out of the repo). Used by the
# reproduce-the-corpus command in the README; not read by the code directly.
URDU_SLM_RAW_DIR=/tmp/urdu-slm-raw

# For the phase-2 DDP launch, torchrun sets these; listed here for reference only.
# WORLD_SIZE=1
# RANK=0
# LOCAL_RANK=0
# MASTER_ADDR=127.0.0.1
# MASTER_PORT=29500
